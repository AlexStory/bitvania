[remap]

importer="csv_translation"
type="Translation"

[deps]

files=[ "res://localization/data.en.translation", "res://localization/data.eo.translation" ]

source_file="res://localization/data.csv"
dest_files=[ "res://localization/data.en.translation", "res://localization/data.eo.translation" ]

[params]

compress=true
delimiter=0
